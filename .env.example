# Google tag (obrigatório para carregar gtag.js). Use o ID da sua tag do Google (ex.: AW-123456789 ou G-XXXXXXXXXX).
# Obtenha em: Google Ads > Ferramentas > Conversões, ou Google Analytics > Administração > Fluxos de dados.
VITE_GTAG_ID=

# Conversão de lead no Google Ads: valor completo "send_to" da ação (formato AW-123456789/label).
# Opcional; sem isso, apenas o evento GA4 abaixo pode ser usado (se configurado).
VITE_GOOGLE_ADS_CONVERSION_SEND_TO=

# Opcional: evento extra no GA4 ao clicar em WhatsApp / enviar formulário (ex.: generate_lead).
VITE_GTAG_LEAD_EVENT_NAME=

# Redes sociais (URLs completas). Ícones no rodapé só aparecem se a variável estiver preenchida.
# VITE_SOCIAL_INSTAGRAM=https://instagram.com/...
# VITE_SOCIAL_FACEBOOK=https://www.facebook.com/...
# VITE_SOCIAL_LINKEDIN=https://www.linkedin.com/company/...
# VITE_SOCIAL_YOUTUBE=https://www.youtube.com/@...
